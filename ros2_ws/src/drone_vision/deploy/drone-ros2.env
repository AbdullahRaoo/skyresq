# /etc/default/drone-ros2
#
# Environment overrides for the SkyResQ drone pipeline. Edit on the Pi
# (sudo nano /etc/default/drone-ros2) and run `sudo systemctl restart
# drone-ros2` to apply.

# ── Flight controller link ────────────────────────────────────────────
CONNECTION_STRING=/dev/serial0
BAUD_RATE=57600

# ── Z-1 Mini gimbal / camera ──────────────────────────────────────────
RTSP_URL=rtsp://192.168.144.108/stream1
GIMBAL_HOST=192.168.144.108
GIMBAL_PORT=2332
GIMBAL_BACKEND=tcp           # tcp = real gimbal, sim = no hardware

# Hardware-accelerated decode pipeline (uncomment on a Pi 4 with v4l2h264dec)
# GST_PIPELINE=rtspsrc location=rtsp://192.168.144.108/stream1 latency=200 ! rtph264depay ! h264parse ! v4l2h264dec ! videoconvert ! video/x-raw,format=BGR ! appsink
GST_PIPELINE=

# ── SkyResQ GCS link ──────────────────────────────────────────────────
GCS_IP=100.123.87.26
GCS_PORT=5005

# ── Detector tuning ───────────────────────────────────────────────────
CONFIDENCE=0.45
DETECTOR_BACKEND=ncnn        # ncnn | onnx | ultralytics

# ── Environment paths (rarely changed) ────────────────────────────────
ROS_DISTRO=jazzy
WORKSPACE=/home/abdullah/Drone/ros2_ws
VENV=/home/abdullah/Drone/venv

# ROS 2 middleware configuration. DDS multicast is fine on a single Pi.
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_DOMAIN_ID=42
