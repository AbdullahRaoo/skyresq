# /etc/default/drone-ros2
#
# Environment overrides for the SkyResQ drone pipeline. Edit on the Pi
# (sudo nano /etc/default/drone-ros2) and run `sudo systemctl restart
# drone-ros2` to apply.

# ── Flight controller link ────────────────────────────────────────────
CONNECTION_STRING=/dev/serial0
BAUD_RATE=57600

# ── Z-1 Mini gimbal / camera ──────────────────────────────────────────
# RTSP source. mediamtx on the Pi is already pulling rtsp://192.168.144.108
# and republishing as 'skyresq_cam' for the SkyResQ WebRTC iframe; we
# piggyback on that local relay so there's a single point of stream
# management on the Pi.
RTSP_URL=rtsp://127.0.0.1:8554/skyresq_cam
GIMBAL_HOST=192.168.144.108
GIMBAL_PORT=2332
GIMBAL_BACKEND=tcp           # tcp = real gimbal, sim = no hardware

# Hardware-accelerated decode pipeline (uncomment for v4l2h264dec on Pi 4)
# GST_PIPELINE=rtspsrc location=rtsp://127.0.0.1:8554/skyresq_cam latency=200 ! rtph264depay ! h264parse ! v4l2h264dec ! videoconvert ! video/x-raw,format=BGR ! appsink
GST_PIPELINE=

# ── SkyResQ GCS link ──────────────────────────────────────────────────
GCS_IP=100.123.87.26
GCS_PORT=5005

# ── Detector tuning ───────────────────────────────────────────────────
CONFIDENCE=0.45
DETECTOR_BACKEND=ncnn        # ncnn | onnx | ultralytics

# ── Environment paths (rarely changed) ────────────────────────────────
# On the Raspberry Pi we use ROS 2 Humble inside a RoboStack conda env
# (Jazzy isn't available for aarch64). On the dev PC ROS 2 lives in
# /opt/ros/jazzy. launch_drone.sh autodetects which to use.
ROS_DISTRO=humble
CONDA_ROOT=/home/pi/miniforge3
CONDA_ENV=ros_humble
WORKSPACE=/home/pi/Drone/ros2_ws

# ROS 2 middleware configuration. DDS multicast is fine on a single Pi.
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_DOMAIN_ID=42
